  function jumpTo(id) {
    const el = document.getElementById(id);
    if (!el.classList.contains('open')) el.classList.add('open');
    setTimeout(() => el.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
  }

  function jumpToAnchor(anchorId, lessonId) {
    const lesson = document.getElementById(lessonId);
    if (lesson && !lesson.classList.contains('open')) {
      lesson.classList.add('open');
    }
    setTimeout(() => {
      const anchor = document.getElementById(anchorId);
      if (anchor) {
        anchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
        anchor.classList.add('highlight-flash');
        setTimeout(() => anchor.classList.remove('highlight-flash'), 1800);
      }
    }, 120);
  }
